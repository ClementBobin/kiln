{
  "name": "React — Vite + TypeScript",
  "description": "React SPA with Vite, TypeScript, Tailwind CSS, React Query, and React Router v6.",
  "version": "1.0.0",
  "tags": ["react", "vite", "typescript", "tailwind", "react-query", "spa"],

  "source": {
    "type": "command",
    "commands": [
      {
        "cmd": "npm create vite@latest {{project_name}}",
        "label": "Run Vite CLI generator"
      }
    ]
  },

  "structure": [
    {"src": {
      "templates": ["react_structure"]
    }},
    "api",
    "pages"
  ],

  "variables": [
    { "key": "project_name", "label": "Project name",      "default": "my-app" },
    { "key": "description",  "label": "Short description", "default": "A React application" }
  ],

  "code_conventions": {
    "editorconfig": true,
    "linter": { "enabled": true, "type": "eslint", "config_file": "eslint.config.mjs" },
    "formatter": { "enabled": true, "type": "prettier" }
  },

  "cicd": {
    "workflows": ["type-check"]
  },

  "post_init": [
    { "cmd": "npm install", "label": "Install dependencies" }
  ]
}
