{
  // ── nodejs/prisma — Prisma ORM setup ────────────────────────────────────
  "name": "Prisma ORM",
  "description": "Installs Prisma + the Postgres driver adapter and runs `prisma init`.",
  "tags": ["nodejs", "prisma", "orm", "database"],

  "variables": [
    { "key": "prisma_output_dir", "label": "Generated client output dir", "default": "../generated/prisma" }
  ],

  "apply": {
    "type": "command",
    "commands": [
      {
        "cmd": "npm install prisma @types/pg --save-dev",
        "label": "Install Prisma (dev dependency)"
      },
      {
        "cmd": "npm install @prisma/client @prisma/adapter-pg pg dotenv",
        "label": "Install Prisma client + Postgres adapter"
      }
    ]
  },

  "post_apply": [
    { "cmd": "npx prisma init --output {{prisma_output_dir}}", "label": "Initialise Prisma schema" }
  ]
}
