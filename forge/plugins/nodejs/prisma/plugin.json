{
  "name": "Prisma ORM",
  "description": "Sets up Prisma ORM: picks your database interactively, writes prisma.config.ts, patches schema.prisma, creates lib/prisma.ts with the right driver adapter, and emits .env.example.",
  "tags": ["nodejs", "prisma", "orm", "database"],

  "variables": [
    {
      "key": "prisma_output_dir",
      "label": "Generated client output dir",
      "default": "../generated/prisma"
    }
  ],

  "dependencies": [
    "prisma --save-dev",
    "@prisma/client",
    "dotenv"
  ],

  "pre_apply": [
    {
      "cmd": "npx prisma init --output {{prisma_output_dir}}",
      "label": "Initialise Prisma schema"
    }
  ]

  "apply": {
    "type": "script",
    "file": "setup_prisma.py",
    "runtime": "python3",
    "install_deps_from_stdout": {
      "marker": "INSTALL_DEPS:",
      "description": "Adapter + sqlcommenter packages selected interactively by the user"
    }
  },

  "post_apply": [
    {
      "cmd": "python3 setup_prisma.py",
      "label": "Configure adapter, schema and lib/prisma.ts"
    }
  ]
}